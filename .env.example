# LLM API Keys (set at least one)
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# Default model selection (provider:model format)
BIG5_DEFAULT_MODEL=openai:gpt-4.1

# Paths (optional; defaults relative to CWD)
BIG5_LOG_DIR=./logs
BIG5_RESULTS_DIR=./results
BIG5_DATA_DIR=./data

# Safety: max concurrent API calls
BIG5_MAX_CONCURRENCY=20
