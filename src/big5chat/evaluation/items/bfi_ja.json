{
  "_description": "BFI-44 (John & Srivastava 1999) - Japanese (content-equivalent placeholder). IDs and item order are aligned with bfi_en.json one-to-one. Translations aim for content equivalence but are NOT a psychometrically validated standard version; for publication, replace with Wada (1996) BFS or Yoshino (2022) BFI-2-J validated items.",
  "language": "ja",
  "version": "bfi44-v1",
  "items": [
    {"id": "E01", "text": "話好きである", "dim": "E", "reversed": false},
    {"id": "A01", "text": "他人のあら探しをしがちだ", "dim": "A", "reversed": true},
    {"id": "C01", "text": "仕事を念入りに行う", "dim": "C", "reversed": false},
    {"id": "N01", "text": "落ち込みやすく、ふさぎ込むことがある", "dim": "N", "reversed": false},
    {"id": "O01", "text": "独創的で、新しいアイデアを思いつく", "dim": "O", "reversed": false},
    {"id": "E02", "text": "控えめである", "dim": "E", "reversed": true},
    {"id": "A02", "text": "他人に親切で、思いやりがある", "dim": "A", "reversed": false},
    {"id": "C02", "text": "ときどき不注意なところがある", "dim": "C", "reversed": true},
    {"id": "N02", "text": "リラックスしていて、ストレスにうまく対処できる", "dim": "N", "reversed": true},
    {"id": "O02", "text": "さまざまなことに好奇心を持つ", "dim": "O", "reversed": false},
    {"id": "E03", "text": "エネルギーに満ちあふれている", "dim": "E", "reversed": false},
    {"id": "A03", "text": "他人と口論をしがちだ", "dim": "A", "reversed": true},
    {"id": "C03", "text": "信頼できる働き手である", "dim": "C", "reversed": false},
    {"id": "N03", "text": "緊張しやすい", "dim": "N", "reversed": false},
    {"id": "O03", "text": "機知に富み、物事を深く考える", "dim": "O", "reversed": false},
    {"id": "E04", "text": "大いに熱意を生み出す", "dim": "E", "reversed": false},
    {"id": "A04", "text": "寛容な性格である", "dim": "A", "reversed": false},
    {"id": "C04", "text": "整理整頓ができない方だ", "dim": "C", "reversed": true},
    {"id": "N04", "text": "よく心配する", "dim": "N", "reversed": false},
    {"id": "O04", "text": "活発な想像力を持っている", "dim": "O", "reversed": false},
    {"id": "E05", "text": "寡黙な方だ", "dim": "E", "reversed": true},
    {"id": "A05", "text": "おおむね他人を信頼する", "dim": "A", "reversed": false},
    {"id": "C05", "text": "怠けがちである", "dim": "C", "reversed": true},
    {"id": "N05", "text": "情緒が安定していて、動揺しにくい", "dim": "N", "reversed": true},
    {"id": "O05", "text": "発明の才がある", "dim": "O", "reversed": false},
    {"id": "E06", "text": "自己主張が強い性格だ", "dim": "E", "reversed": false},
    {"id": "A06", "text": "冷たく無関心になることがある", "dim": "A", "reversed": true},
    {"id": "C06", "text": "やり遂げるまで頑張り続ける", "dim": "C", "reversed": false},
    {"id": "N06", "text": "気分屋になることがある", "dim": "N", "reversed": false},
    {"id": "O06", "text": "芸術的・美的経験を大切にする", "dim": "O", "reversed": false},
    {"id": "E07", "text": "ときに内気で控えめになる", "dim": "E", "reversed": true},
    {"id": "A07", "text": "ほとんど誰にでも思いやりがあり親切だ", "dim": "A", "reversed": false},
    {"id": "C07", "text": "物事を効率的に行う", "dim": "C", "reversed": false},
    {"id": "N07", "text": "緊迫した状況でも冷静さを保つ", "dim": "N", "reversed": true},
    {"id": "O07", "text": "決まりきった仕事を好む", "dim": "O", "reversed": true},
    {"id": "E08", "text": "外向的で社交的である", "dim": "E", "reversed": false},
    {"id": "A08", "text": "ときに他人に対して無礼になる", "dim": "A", "reversed": true},
    {"id": "C08", "text": "計画を立て、それを最後まで実行する", "dim": "C", "reversed": false},
    {"id": "N08", "text": "すぐに神経質になる", "dim": "N", "reversed": false},
    {"id": "O08", "text": "考えごとや思索を楽しむ", "dim": "O", "reversed": false},
    {"id": "O09", "text": "芸術への興味がほとんどない", "dim": "O", "reversed": true},
    {"id": "A09", "text": "他人と協力するのを好む", "dim": "A", "reversed": false},
    {"id": "C09", "text": "気が散りやすい", "dim": "C", "reversed": true},
    {"id": "O10", "text": "芸術、音楽、文学に造詣が深い", "dim": "O", "reversed": false}
  ]
}
